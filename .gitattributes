# v0.32.0: the SPA build output lives under
# `crates/coral-ui/assets/dist/`. It is committed so end-users don't
# need Node/npm to install Coral (the Rust binary embeds it via
# `include_dir!`). However:
#
#   - linguist-generated=true keeps GitHub's language stats honest and
#     hides the bundle from default `git diff` views.
#   - merge=ours auto-resolves merge conflicts in dist/ by keeping the
#     branch's version. CI rebuilds and verifies sync after the merge.
#
# Source of truth is always `crates/coral-ui/assets/src/`.

crates/coral-ui/assets/dist/** linguist-generated=true merge=ours

# Force LF on every text artifact under dist/. Without this, Windows
# devs commit CRLF and the CI drift check (which runs on Linux) sees
# a 100% diff against its fresh build. LF is what Vite emits.
crates/coral-ui/assets/dist/**/*.html text eol=lf
crates/coral-ui/assets/dist/**/*.js text eol=lf
crates/coral-ui/assets/dist/**/*.css text eol=lf
crates/coral-ui/assets/dist/**/*.svg text eol=lf
crates/coral-ui/assets/dist/**/*.json text eol=lf
crates/coral-ui/assets/dist/**/*.map text eol=lf

# node_modules is gitignored, but in case something slips, mark it.
crates/coral-ui/assets/src/node_modules/** linguist-vendored=true

# Lockfiles are generated artifacts but kept under VC for reproducibility.
Cargo.lock linguist-generated=false
crates/coral-ui/assets/src/package-lock.json linguist-generated=true

# v0.34.0 FR-ONB-9: Claude Code SessionStart hook scripts. Forced LF on
# every platform — the bash wrapper + .sh sibling depend on LF line
# endings (CRLF breaks the `#!/usr/bin/env bash` shebang). The .ps1 is
# tolerant of either but we pin LF for consistency with the rest of
# the plugin payload.
.claude-plugin/scripts/on-session-start text eol=lf
.claude-plugin/scripts/on-session-start.sh text eol=lf
.claude-plugin/scripts/on-session-start.ps1 text eol=lf

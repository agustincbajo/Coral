{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StatsReport",
  "description": "Aggregated wiki health metrics.",
  "type": "object",
  "required": [
    "archived_count",
    "by_status",
    "by_type",
    "confidence_avg",
    "confidence_max",
    "confidence_min",
    "critical_low_confidence_count",
    "low_confidence_count",
    "orphan_candidates",
    "stale_count",
    "total_outbound_links",
    "total_pages"
  ],
  "properties": {
    "archived_count": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "by_status": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "format": "uint",
        "minimum": 0.0
      }
    },
    "by_type": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "format": "uint",
        "minimum": 0.0
      }
    },
    "confidence_avg": {
      "type": "number",
      "format": "double"
    },
    "confidence_max": {
      "type": "number",
      "format": "double"
    },
    "confidence_min": {
      "type": "number",
      "format": "double"
    },
    "critical_low_confidence_count": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "low_confidence_count": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "orphan_candidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stale_count": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "total_outbound_links": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "total_pages": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StatsReport",
  "description": "Aggregated wiki health metrics.",
  "type": "object",
  "required": [
    "archived_count",
    "by_status",
    "by_type",
    "confidence_avg",
    "confidence_max",
    "confidence_min",
    "critical_low_confidence_count",
    "low_confidence_count",
    "oldest_commit_age_pages",
    "orphan_candidates",
    "pages_by_confidence_bucket",
    "pages_without_sources_count",
    "stale_count",
    "total_outbound_links",
    "total_pages"
  ],
  "properties": {
    "archived_count": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "by_status": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "format": "uint",
        "minimum": 0.0
      }
    },
    "by_type": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "format": "uint",
        "minimum": 0.0
      }
    },
    "confidence_avg": {
      "type": "number",
      "format": "double"
    },
    "confidence_max": {
      "type": "number",
      "format": "double"
    },
    "confidence_min": {
      "type": "number",
      "format": "double"
    },
    "critical_low_confidence_count": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "low_confidence_count": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "oldest_commit_age_pages": {
      "description": "Slugs of the 5 pages with the oldest `last_updated_commit`, sorted ascending by commit string then slug. Useful for spotting long-untouched pages that may have drifted from HEAD. (Future improvement: real timestamp comparison via `git log`.)",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "orphan_candidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pages_by_confidence_bucket": {
      "description": "Confidence distribution into 4 buckets. Keys: `\"0.0-0.3\"`, `\"0.3-0.6\"`, `\"0.6-0.8\"`, `\"0.8-1.0\"`. Empty buckets are still listed (with value 0) so the JSON shape is stable.",
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "format": "uint",
        "minimum": 0.0
      }
    },
    "pages_without_sources_count": {
      "description": "Count of pages where `frontmatter.sources` is empty. A high value means many pages lack verifiable evidence — pair with the lint's `HighConfidenceWithoutSources` check to find the worst offenders.",
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "stale_count": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "total_outbound_links": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "total_pages": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    }
  }
}
